{
  "name": "@ossl/genesis-plugins",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/plugins/node/index.js",
      "types": "./dist/plugins/node/index.d.ts"
    },
    "./python": {
      "import": "./dist/plugins/python/index.js",
      "types": "./dist/plugins/python/index.d.ts"
    },
    "./java": {
      "import": "./dist/plugins/java/index.js",
      "types": "./dist/plugins/java/index.d.ts"
    },
    "./go": {
      "import": "./dist/plugins/go/index.js",
      "types": "./dist/plugins/go/index.d.ts"
    },
    "./git": {
      "import": "./dist/plugins/git/index.js",
      "types": "./dist/plugins/git/index.d.ts"
    },
    "./docker": {
      "import": "./dist/plugins/docker/index.js",
      "types": "./dist/plugins/docker/index.d.ts"
    },
    "./homebrew": {
      "import": "./dist/plugins/homebrew/index.js",
      "types": "./dist/plugins/homebrew/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/plugins/node/index.ts src/plugins/python/index.ts src/plugins/java/index.ts src/plugins/go/index.ts src/plugins/git/index.ts src/plugins/docker/index.ts src/plugins/homebrew/index.ts --dts --format esm --minify",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "dependencies": {
    "@ossl/genesis-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.0.0",
    "eslint": "^9.0.0",
    "@types/node": "^22.0.0",
    "vitest": "^2.0.0"
  }
}
